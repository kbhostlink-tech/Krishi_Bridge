// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────

enum UserRole {
  FARMER
  BUYER
  AGGREGATOR
  ADMIN
}

enum SellerType {
  INDIVIDUAL_FARMER
  AGGREGATOR
  FPO_COOPERATIVE
  TRADER
  PROCESSOR
}

enum BuyerType {
  IMPORTER
  EXPORTER
  BLENDER_PROCESSOR
  WHOLESALER
  INSTITUTIONAL
  TRADER
}

enum AdminRole {
  SUPER_ADMIN
  COMPLIANCE_ADMIN
  OPS_ADMIN
  DATA_AUDIT_ADMIN
  READ_ONLY_ADMIN
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum CommodityType {
  LARGE_CARDAMOM
  TEA
  GINGER
  TURMERIC
  PEPPER
  COFFEE
  SAFFRON
  ARECA_NUT
  CINNAMON
  OTHER
}

enum Grade {
  PREMIUM
  A
  B
  C
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  LISTED
  REJECTED
}

enum LotStatus {
  DRAFT
  PENDING_APPROVAL
  LISTED
  AUCTION_ACTIVE
  UNDER_RFQ
  SOLD
  REDEEMED
  EXPIRED
  CANCELLED
}

enum ListingMode {
  AUCTION
  RFQ
  BOTH
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  CANCELLED
}

enum TokenStatus {
  ACTIVE
  TRANSFERRED
  REDEEMED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  ESCROW_HELD
  MANUAL_CONFIRMED
  COMPLETED
  FUNDS_RELEASED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  ESEWA
  KHALTI
  BANK_TRANSFER
  STRIPE
  TAP
  WISE
  MANUAL_OFFLINE
}

enum CountryCode {
  IN
  NP
  BT
  AE
  SA
  OM
}

enum CurrencyCode {
  INR
  NPR
  BTN
  AED
  SAR
  OMR
  USD
}

enum RfqStatus {
  OPEN
  ROUTED
  RESPONDED
  NEGOTIATING
  SELECTED
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum RfqResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  COUNTERED
}

enum NotificationType {
  EMAIL
  PUSH
  IN_APP
}

// ─── USER & KYC ──────────────────────────────

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  phone             String?      @unique
  passwordHash      String
  name              String
  role              UserRole
  country           CountryCode
  preferredCurrency CurrencyCode
  preferredLang     String       @default("en")
  notificationPrefs Json?        // { email: true, push: true, inApp: true, quietHoursStart?: string, quietHoursEnd?: string }
  kycStatus         KycStatus    @default(PENDING)
  isActive          Boolean      @default(true)
  emailVerified         Boolean      @default(false)
  onboardingComplete    Boolean      @default(false)
  tokenVersion          Int          @default(0)
  adminRole             AdminRole?
  uniquePaymentCode     String?      @unique  // e.g. "MJ0001" — used by buyer to identify payments
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  buyerProfile          BuyerProfile?
  sellerProfile         SellerProfile?
  kycDocuments          KycDocument[]
  farmerLots            Lot[]             @relation("FarmerLots")
  sellerLots            Lot[]             @relation("SellerLots")
  commoditySubmissions  CommoditySubmission[] @relation("FarmerSubmissions")
  bids                  Bid[]
  tokens                Token[]           @relation("TokenOwner")
  sentTransfers         TokenTransfer[]   @relation("TransferFrom")
  receivedTransfers     TokenTransfer[]   @relation("TransferTo")
  buyerTransactions     Transaction[]     @relation("BuyerTransactions")
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  rfqRequests           RfqRequest[]      @relation("BuyerRfqs")
  rfqResponses          RfqResponse[]     @relation("SellerRfqResponses")
  rfqNegotiations       RfqNegotiation[]
  otpCodes              OtpCode[]
  adminInvitationsSent  AdminInvitation[] @relation("AdminInvitedBy")

  @@index([role, kycStatus])
  @@index([country])
}

model OtpCode {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String
  attempts    Int      @default(0)
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model KycDocument {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  docType     String
  docUrl      String
  verifiedAt  DateTime?
  verifiedBy  String?
  remarks     String?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ─── BUYER & SELLER PROFILES ─────────────────

model BuyerProfile {
  id                      String    @id @default(uuid())
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName             String
  tradeName               String?
  buyerType               BuyerType
  fullAddress             String    @db.Text
  city                    String?
  website                 String?
  contactDesignation      String?   // Primary contact's designation
  alternateContact        String?   // Alternate contact name/number
  mobile                  String?   // Mobile / WhatsApp
  registrationNumber      String?
  taxId                   String?
  importExportLicense     String?
  yearsInBusiness         Int?
  typicalMonthlyVolumeMin Float?
  typicalMonthlyVolumeMax Float?
  preferredOrigins        String[]
  preferredGrades         String[]
  packagingPreference     String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model SellerProfile {
  id                        String     @id @default(uuid())
  userId                    String     @unique
  user                      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sellerType                SellerType
  entityName                String?
  contactPersonName         String?   // Primary contact person
  mobile                    String?   // Mobile / WhatsApp
  languagePreference        String?   // Preferred communication language
  state                     String?
  district                  String?
  village                   String?
  registrationId            String?
  fpoName                   String?
  yearsOfActivity           Int?
  typicalAnnualVolume       Float?
  originRegion              String?
  harvestSeason             String?
  postHarvestProcess        String?
  indicativePriceExpectation Float?    // CONFIDENTIAL — never exposed to buyers
  minAcceptableQuantity     Float?
  willingToNegotiate        Boolean   @default(true)
  // Bank account details (admin/super-admin visible only)
  bankAccountName           String?   // Account holder name
  bankAccountNumber         String?   // Account number
  bankName                  String?   // Bank name
  bankBranch                String?   // Branch name
  bankIfscCode              String?   // IFSC / SWIFT / routing code
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

// ─── COMMODITY SUBMISSIONS (Farmer → Seller) ──

model CommoditySubmission {
  id              String           @id @default(uuid())
  farmerId        String
  farmer          User             @relation("FarmerSubmissions", fields: [farmerId], references: [id])
  commodityType   CommodityType
  grade           Grade?
  variety         String?          // Variety/cultivar name
  quantityKg      Decimal
  numberOfBags    Int?             // Number of bags
  bagWeight       Float?           // Weight per bag in kg
  packagingType   String?          // Jute, Poly, Vacuum, etc.
  description     String?          @db.Text
  images          String[]
  videos          String[]         // Video URLs (up to 5)
  origin          Json             // { country, state, district, village? }
  harvestDate     DateTime?
  harvestYear     Int?             // e.g. 2025
  harvestMonth    String?          // e.g. "October"
  harvestSeason   String?
  // Product specifications
  moistureRange   String?          // e.g. "10-12%"
  colourAroma     String?          // Colour / Aroma description
  tailCut         String?          // "Tail-Cut" or "Uncut" or other
  // Compliance & Documents
  sellerDeclaration String?        @db.Text
  labReportUrl    String?          // Lab report file URL
  phytosanitaryUrl String?         // Phytosanitary certificate URL
  originCertUrl   String?          // Origin certificate URL
  status          SubmissionStatus @default(SUBMITTED)
  adminRemarks    String?          @db.Text
  lotId           String?          // Linked lot once seller creates listing
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([farmerId])
  @@index([status])
  @@index([commodityType])
}

// ─── WAREHOUSE & LOTS ────────────────────────

model Warehouse {
  id          String      @id @default(uuid())
  name        String
  country     CountryCode
  state       String?
  district    String?
  address     String
  lat         Float?
  lng         Float?
  managerId   String?
  phone       String?
  email       String?
  maxCapacity Int?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lots        Lot[]
}

model Lot {
  id              String        @id @default(uuid())
  lotNumber       String        @unique
  sellerId        String
  seller          User          @relation("SellerLots", fields: [sellerId], references: [id])
  farmerId        String?
  farmer          User?         @relation("FarmerLots", fields: [farmerId], references: [id])
  submissionId    String?       // Link to farmer's commodity submission
  warehouseId     String?
  warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id])
  commodityType   CommodityType
  grade           Grade
  quantityKg      Decimal
  description     String?       @db.Text
  images          String[]
  videos          String[]
  origin          Json
  status          LotStatus     @default(DRAFT)
  listingMode     ListingMode   @default(AUCTION)

  startingPriceInr    Decimal?
  reservePriceInr     Decimal?
  auctionStartsAt     DateTime?
  auctionEndsAt       DateTime?
  sellerDeclaration   String?       @db.Text
  labReportUrl        String?
  phytosanitaryUrl    String?
  originCertUrl       String?
  adminRemarks        String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qualityCheck QualityCheck?
  qrCode       QrCode?
  bids         Bid[]
  token        Token?
  transactions Transaction[]
  rfqResponses RfqResponse[]

  @@index([status, commodityType])
  @@index([sellerId])
  @@index([farmerId])
  @@index([auctionEndsAt])
}

model QualityCheck {
  id          String   @id @default(uuid())
  lotId       String   @unique
  lot         Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  moisturePct Float?
  podSizeMm   Float?
  colourGrade String?
  labCertUrl  String?
  inspectedBy String
  inspectedAt DateTime @default(now())
  notes       String?  @db.Text
}

model QrCode {
  id            String   @id @default(uuid())
  lotId         String   @unique
  lot           Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  qrData        String   @db.Text
  qrImageUrl    String
  hmacSignature String
  createdAt     DateTime @default(now())
}

// ─── BIDDING ─────────────────────────────────

model Bid {
  id          String     @id @default(uuid())
  lotId       String
  lot         Lot        @relation(fields: [lotId], references: [id])
  bidderId    String
  bidder      User       @relation(fields: [bidderId], references: [id])
  amountInr   Decimal
  currency    CurrencyCode
  localAmount Decimal
  status      BidStatus  @default(ACTIVE)
  isProxy     Boolean    @default(false)
  maxProxyInr Decimal?
  createdAt   DateTime   @default(now())

  @@index([lotId, amountInr])
  @@index([bidderId])
}

// ─── PAYMENTS & TRANSACTIONS ─────────────────

model Transaction {
  id               String        @id @default(uuid())
  lotId            String?
  lot              Lot?          @relation(fields: [lotId], references: [id])
  rfqId            String?
  buyerId          String
  buyer            User          @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId         String
  gatewayOrderId   String?
  gatewayPaymentId String?
  paymentMethod    PaymentMethod
  currency         CurrencyCode
  grossAmount      Decimal
  commissionAmount Decimal
  taxOnGoods       Decimal
  taxOnCommission  Decimal
  netToSeller      Decimal
  status              PaymentStatus @default(PENDING)
  idempotencyKey      String        @unique
  paidAt              DateTime?
  escrowReleasedAt    DateTime?
  manualPaymentRef    String?       // UPI ref / bank transfer ref / etc.
  manualConfirmedBy   String?       // sellerId who confirmed payment received
  manualConfirmedAt   DateTime?     // When seller confirmed
  adminConfirmedBy    String?       // Admin who confirmed payment received
  adminConfirmedAt    DateTime?     // When admin confirmed buyer payment
  fundsReleasedBy     String?       // Admin who released funds to seller
  fundsReleasedAt     DateTime?     // When funds were released to seller
  buyerReceivedAt     DateTime?     // When buyer confirmed receiving goods
  createdAt           DateTime      @default(now())

  @@index([buyerId])
  @@index([lotId])
  @@index([status])
}

// ─── TOKEN & TRANSFERS ───────────────────────

model Token {
  id         String      @id @default(uuid())
  lotId      String?     @unique
  lot        Lot?        @relation(fields: [lotId], references: [id])
  rfqId      String?     @unique
  rfq        RfqRequest? @relation(fields: [rfqId], references: [id])
  ownerId    String
  owner      User        @relation("TokenOwner", fields: [ownerId], references: [id])
  status     TokenStatus @default(ACTIVE)
  hmacHash   String
  mintedAt   DateTime    @default(now())
  expiresAt  DateTime
  redeemedAt DateTime?

  transfers TokenTransfer[]

  @@index([ownerId, status])
}

model TokenTransfer {
  id            String   @id @default(uuid())
  tokenId       String
  token         Token    @relation(fields: [tokenId], references: [id])
  fromUserId    String
  fromUser      User     @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId      String
  toUser        User     @relation("TransferTo", fields: [toUserId], references: [id])
  priceInr      Decimal?
  transferredAt DateTime @default(now())

  @@index([tokenId])
}

// ─── RFQ ─────────────────────────────────────

model RfqRequest {
  id                 String        @id @default(uuid())
  buyerId            String
  buyer              User          @relation("BuyerRfqs", fields: [buyerId], references: [id])
  commodityType      CommodityType
  grade              Grade?
  quantityKg         Decimal
  targetPriceInr     Decimal?
  targetCurrency     CurrencyCode?
  adminPriceInr      Decimal?
  deliveryCountry    CountryCode
  deliveryCity       String
  description        String?       @db.Text
  status             RfqStatus     @default(OPEN)
  responseCount      Int           @default(0)
  routedSellerIds    String[]
  selectedResponseId String?
  finalPriceInr      Decimal?
  adminNotes         String?       @db.Text
  expiresAt          DateTime
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  responses RfqResponse[]
  token     Token?

  @@index([status, commodityType])
  @@index([buyerId])
  @@index([expiresAt])
}

model RfqResponse {
  id                   String            @id @default(uuid())
  rfqId                String
  rfq                  RfqRequest        @relation(fields: [rfqId], references: [id])
  sellerId             String
  seller               User              @relation("SellerRfqResponses", fields: [sellerId], references: [id])
  lotId                String?
  lot                  Lot?              @relation(fields: [lotId], references: [id])
  offeredPriceInr      Decimal
  currency             CurrencyCode
  deliveryDays         Int
  notes                String?           @db.Text
  status               RfqResponseStatus @default(PENDING)
  adminForwarded       Boolean           @default(false)
  adminEditedPriceInr  Decimal?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  negotiations RfqNegotiation[]

  @@unique([rfqId, sellerId])
  @@index([rfqId])
  @@index([sellerId])
}

model RfqNegotiation {
  id                 String      @id @default(uuid())
  responseId         String
  response           RfqResponse @relation(fields: [responseId], references: [id])
  fromUserId         String
  fromUser           User        @relation(fields: [fromUserId], references: [id])
  message            String      @db.Text
  proposedPriceInr   Decimal?
  proposedQuantityKg Decimal?
  createdAt          DateTime    @default(now())

  @@index([responseId])
}

// ─── NOTIFICATIONS ───────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

// ─── FX RATES ────────────────────────────────

model FxRate {
  id           String       @id @default(uuid())
  fromCurrency CurrencyCode
  toCurrency   CurrencyCode
  rate         Decimal
  source       String       @default("wise")
  fetchedAt    DateTime     @default(now())

  @@unique([fromCurrency, toCurrency])
}

// ─── AUDIT LOG ───────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ─── PLATFORM SETTINGS ──────────────────────

model PlatformSettings {
  id                  String   @id @default(uuid())
  key                 String   @unique  // e.g. "platform_bank_account"
  value               Json     // Flexible JSON storage
  updatedBy           String?  // Admin ID who last updated
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── PUSH SUBSCRIPTIONS ─────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("web")
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── ADMIN INVITATIONS ──────────────────────

enum AdminInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model AdminInvitation {
  id            String            @id @default(uuid())
  email         String
  name          String
  adminRole     AdminRole
  tokenHash     String            @unique   // SHA-256 hash of invite token (never store raw)
  status        AdminInviteStatus @default(PENDING)
  expiresAt     DateTime
  acceptedAt    DateTime?
  acceptedBy    String?           // userId of the created admin
  revokedAt     DateTime?
  invitedBy     String
  invitedByUser User              @relation("AdminInvitedBy", fields: [invitedBy], references: [id])
  createdAt     DateTime          @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([status])
}
